<!--This network adapter configuration defines a LAN profile with 802.1X authentication DISABLED for MAB (MAC Authentication Bypass) testing-->
<!--When 802.1X is disabled, the switch will use MAB to authenticate the endpoint based on its MAC address-->

<LANProfile xmlns="http://www.microsoft.com/networking/LAN/profile/v1">
  <MSM>
    <security>
      <OneXEnforced>false</OneXEnforced>
      <OneXEnabled>false</OneXEnabled>
    </security>
  </MSM>
</LANProfile>

